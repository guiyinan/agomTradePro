# Core
SECRET_KEY=change-this-to-a-strong-secret
AGOMSAAF_ENCRYPTION_KEY=
DEBUG=False
DJANGO_SETTINGS_MODULE=core.settings.production
ALLOWED_HOSTS=127.0.0.1,localhost,141.11.211.21

# CORS Configuration (for API access from browsers)
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://141.11.211.21:8000
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,http://141.11.211.21:8000

# Runtime image tags
WEB_IMAGE=agomsaaf-web:latest
REDIS_IMAGE=redis:7-alpine
CADDY_IMAGE=caddy:2-alpine
RSSHUB_IMAGE=diygod/rsshub:latest

# Django data source URLs (SQLite-first)
DATABASE_URL=sqlite:////app/data/db.sqlite3
REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=256mb

# Optional domain for Caddy
DOMAIN=
# Host port mapping for Caddy
CADDY_HTTP_PORT=8000
CADDY_HTTPS_PORT=443

# Service toggles for low-memory VPS
ENABLE_RSSHUB=true
ENABLE_CELERY=false
AGOMSAAF_BOOTSTRAP_ON_START=1
AGOMSAAF_BOOTSTRAP_ALPHA_ON_START=1
AGOMSAAF_BOOTSTRAP_ALPHA_UNIVERSES=csi300
AGOMSAAF_BOOTSTRAP_ALPHA_TOP_N=30

# Gunicorn tuning for 4G VPS
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# Security (HTTP/HTTPS)
# If you run behind plain HTTP (e.g. Caddy mapped to :8000), set these to disable forced HTTPS.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Optional superuser bootstrap
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Optional app keys
TUSHARE_TOKEN=
FRED_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
