# Core
# Leave empty to auto-generate on first boot (persisted in data volume).
# Or set explicitly:
#   SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#   AGOMTRADEPRO_ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=
AGOMTRADEPRO_ENCRYPTION_KEY=
DEBUG=False
DJANGO_SETTINGS_MODULE=core.settings.production
ALLOWED_HOSTS=127.0.0.1,localhost,your-vps-ip

# CORS Configuration
# Leave origin allow-lists unset for same-origin deployment. Production settings
# will derive sane defaults from ALLOWED_HOSTS + SECURE_SSL_REDIRECT.
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=True

# Runtime image tags
WEB_IMAGE=agomtradepro-web:latest
REDIS_IMAGE=redis:7-alpine
CADDY_IMAGE=caddy:2-alpine
RSSHUB_IMAGE=diygod/rsshub:latest

# Django data source URLs (SQLite-first)
DATABASE_URL=sqlite:////app/data/db.sqlite3
REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=256mb

# Optional domain for Caddy. Set this for automatic HTTPS on 80/443.
DOMAIN=
# Host port mapping for Caddy. Use 80/443 for a normal public site.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Service toggles for low-memory VPS
ENABLE_RSSHUB=true
ENABLE_CELERY=false
AGOMTRADEPRO_BOOTSTRAP_ON_START=1
AGOMTRADEPRO_BOOTSTRAP_ALPHA_ON_START=1
AGOMTRADEPRO_BOOTSTRAP_ALPHA_UNIVERSES=csi300
AGOMTRADEPRO_BOOTSTRAP_ALPHA_TOP_N=30
AGOMTRADEPRO_AUTO_MIGRATE_ON_START=1
MACRO_SYNC_HOUR=8
MACRO_SYNC_MINUTE=5

# Gunicorn tuning for 4G VPS
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# Security (HTTP/HTTPS)
# The deploy helper will turn these on automatically when DOMAIN is configured.
# For manual HTTP-only deployments, set them to False/0 before starting compose.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Optional superuser bootstrap
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Optional app keys
TUSHARE_TOKEN=
FRED_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
