# Core
SECRET_KEY=change-this-to-a-strong-secret
DEBUG=False
DJANGO_SETTINGS_MODULE=core.settings.production
ALLOWED_HOSTS=127.0.0.1,localhost

# Runtime image tags
WEB_IMAGE=agomsaaf-web:latest
POSTGRES_IMAGE=postgres:15-alpine
REDIS_IMAGE=redis:7-alpine
CADDY_IMAGE=caddy:2-alpine

# Database
POSTGRES_DB=agomsaaf
POSTGRES_USER=agomsaaf
POSTGRES_PASSWORD=change-this-password

# Django data source URLs
DATABASE_URL=postgresql://agomsaaf:change-this-password@postgres:5432/agomsaaf
REDIS_URL=redis://redis:6379/0

# Optional domain for Caddy
DOMAIN=

# Optional superuser bootstrap
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Optional app keys
TUSHARE_TOKEN=
FRED_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
