# Core
SECRET_KEY=change-this-to-a-strong-secret
DEBUG=False
DJANGO_SETTINGS_MODULE=core.settings.production
ALLOWED_HOSTS=127.0.0.1,localhost

# Runtime image tags
WEB_IMAGE=agomsaaf-web:latest
REDIS_IMAGE=redis:7-alpine
CADDY_IMAGE=caddy:2-alpine
RSSHUB_IMAGE=diygod/rsshub:latest

# Django data source URLs (SQLite-first)
DATABASE_URL=sqlite:////app/data/db.sqlite3
REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=256mb

# Optional domain for Caddy
DOMAIN=

# Service toggles for low-memory VPS
ENABLE_RSSHUB=true
ENABLE_CELERY=false

# Gunicorn tuning for 4G VPS
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# Optional superuser bootstrap
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

# Optional app keys
TUSHARE_TOKEN=
FRED_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
