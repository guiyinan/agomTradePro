# Qlib train runtime environment
# Copy to: deploy/.env.qlib-train

DJANGO_SETTINGS_MODULE=core.settings.production
SECRET_KEY=change-this-to-a-real-secret
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost

# If your Django app uses sqlite in repo root, this default works with the project mounted into /app.
# For PostgreSQL, replace with your actual connection string, for example:
# DATABASE_URL=postgresql://agomtradepro:changeme@host.docker.internal:5433/agomtradepro
DATABASE_URL=sqlite:////app/db.sqlite3

# The Django web app and this worker must point at the same broker.
REDIS_URL=redis://host.docker.internal:6379/0
REDIS_HOST=host.docker.internal
REDIS_PORT=6379

# Qlib runtime paths inside the container.
QLIB_PROVIDER_URI=/qlib_data/cn_data
QLIB_MODEL_PATH=/models/qlib
QLIB_REGION=CN

# Optional data-source keys
TUSHARE_TOKEN=
FRED_API_KEY=
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
