{
  "mcpServers": {
    "agomtradepro": {
      "command": "python",
      "args": ["-m", "agomtradepro_mcp"],
      "cwd": "/path/to/agomTradePro/sdk",
      "env": {
        "AGOMTRADEPRO_BASE_URL": "http://127.0.0.1:8000",
        "AGOMTRADEPRO_API_TOKEN": "your-api-token-here",
        "AGOMTRADEPRO_MCP_ROLE": "viewer",
        "AGOMTRADEPRO_DEFAULT_PORTFOLIO_ID": "1",
        "PYTHONPATH": "/path/to/agomTradePro/sdk"
      }
    }
  }
}
