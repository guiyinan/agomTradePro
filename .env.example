# ============================================
# AgomTradePro Environment Configuration
# ============================================
# Copy this file to .env and update values
# Windows: copy .env.example .env
# Linux/Mac: cp .env.example .env

# -----------------
# Django Settings
# -----------------
# Both keys will be auto-generated by the setup wizard if left empty.
# Or generate manually:
#   SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
#   AGOMTRADEPRO_ENCRYPTION_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=change-this-to-a-secure-random-string-in-production
AGOMTRADEPRO_ENCRYPTION_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_PORT=8000

# -----------------
# Database Configuration
# -----------------
# For SQLite (default, no setup required):
#   - Leave DATABASE_URL empty or comment it out
#   - Uses db.sqlite3 in project root
#
# For PostgreSQL with Docker:
#   - Run: docker-compose -f docker-compose-dev.yml up -d
#   - Use: postgresql://agomtradepro:changeme@localhost:5433/agomtradepro
#   - Note: Port 5433 is used to avoid conflicts

DATABASE_URL=postgresql://agomtradepro:changeme@localhost:5433/agomtradepro

# Docker PostgreSQL password (must match docker-compose-dev.yml)
POSTGRES_PASSWORD=changeme

# -----------------
# Redis Configuration
# -----------------
# For Celery task queue (optional, required only for async tasks)
# Docker: docker-compose -f docker-compose-dev.yml up -d
REDIS_URL=redis://localhost:6379/0

# -----------------
# Celery Configuration
# -----------------
# Skip Celery startup (set to 1 to disable Celery)
SKIP_CELERY=0

# -----------------
# Data Source API Keys
# -----------------
# Tushare Pro (Chinese stock data)
# Register at: https://tushare.pro/register
TUSHARE_TOKEN=

# FRED Economic Data (US macro data)
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# -----------------
# AI Provider API Keys (Optional)
# -----------------
# OpenAI (GPT models)
OPENAI_API_KEY=

# Alibaba DashScope (Qwen models)
DASHSCOPE_API_KEY=

# -----------------
# Sentry Error Tracking (Production)
# -----------------
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
SENTRY_ENVIRONMENT=production

# -----------------
# Database Connection Pool (Production)
# -----------------
DB_CONN_MAX_AGE=600

# -----------------
# Logging
# -----------------
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
DJANGO_LOG_LEVEL=INFO

# -----------------
# Feature Flags
# -----------------
# Enable/disable specific features
ENABLE_TEACHING_MODULE=True
ENABLE_AUDIT_TRAIL=True
STREAMLIT_DASHBOARD_ENABLED=False

# -----------------
# Streamlit Dashboard
# -----------------
# Used when STREAMLIT_DASHBOARD_ENABLED=True
STREAMLIT_DASHBOARD_URL=http://127.0.0.1:8501
