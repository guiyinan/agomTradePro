# Database
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@localhost:5432/agomsaaf

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Data Source API Keys
TUSHARE_TOKEN=your_tushare_pro_token_here
FRED_API_KEY=your_fred_api_key_here

# Optional: Backup data sources
JUHE_API_KEY=
NETEASE_COOKIE=

# Alerting - Email
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=your_email@gmail.com
ALERT_SMTP_PASSWORD=your_app_password
ALERT_EMAIL_FROM=your_email@gmail.com
ALERT_EMAIL_TO=recipient1@example.com,recipient2@example.com

# Alerting - Slack
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Alerting - DingTalk
ALERT_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=YOUR_TOKEN

# Alerting - WeChat Work
ALERT_WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# Django
SECRET_KEY=your-secret-key-here-generate-with-python-manage-py-generate-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production (optional)
# POSTGRES_PASSWORD=changeme
# SECURE_SSL_REDIRECT=True

